{% extends 'base/website.html.twig' %}

{% block main %}
    <a href="{{path('app_forum_public')}}" class="btn btn-primary">Retour</a>
    <form action="{{path('app_forum_public_new_subject')}}" method="POST" class="mt-3">
        <div>
            <label for="title">Titre</label>
            <input type="text" name="title" id="title" placeholder="Titre du sujet">
        </div>
        <input type="hidden" name="_token" value="{{csrf_token('new_subject')}}">
        <div class="mb-3">
            <label for="content">Premier Message</label>
            <input type="textarea" name="content" id="content" placeholder="">
        </div>
        <button type="submit" class="btn btn-success">Envoyer</button>
   </form>


{% endblock %}