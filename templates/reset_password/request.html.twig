{% extends 'base/login.html.twig' %}

{% block title %}Réinitialisation du mot de passe{% endblock %}

{% block main %}
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger w-75 mx-auto" role="alert">{{ flash_error }}</div>
    {% endfor %}

    <div class="d-flex justify-content-center" style="height: 23rem;">
        <div class="form_center shadow p-3 d-flex flex-column justify-content-evenly">
            <div class="d-flex justify-content-center"><h2 class="fw-semibold fs-4">Requête changement de mot de passe</h2></div>
            <div class="middle_form">
                {{ form_start(requestForm) }}
                    {{ form_row(requestForm.email) }}
                    <div>
                        <small>
                            Entrez l'email de votre compte, un lien vous sera envoyé pour changer votre mot de passe.
                        </small>
                    </div>
                    <button class="btn btn-primary mt-3">Envoyer</button>
                {{ form_end(requestForm) }}
            </div>
        </div>
    </div>
{% endblock %}
