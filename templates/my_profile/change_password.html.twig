{% extends 'base/website.html.twig' %}

{% block title %}Changement de mot de passe{% endblock %}

{% block main %}
    <!-- Changement de mot de passe -->
<div class="card border-0 rounded-4 shadow-sm p-4 mb-4">
    <h5 class="fw-bold mb-4" style="color: #1a2e44;">
        <i class="fa-solid fa-lock me-2" style="color: #00897b;"></i>Changer le mot de passe
    </h5>
    
    {% for message in app.flashes('error_password') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

        {{form_start(form,{'attr': {'novalidate': 'novalidate', 'class': 'w-100'}})}}
        <input type="hidden" name="_token" value="{{ csrf_token('change_password') }}">
        <div class="mb-3">
            <label class="fw-semibold mb-1">Ancien mot de passe</label>
            {{form_widget(form.oldPassword)}}
            <span class="form_errors">{{form_errors(form.oldPassword)}}</span>
           {% for message in app.flashes('error') %}
                <span class="form_errors">
                    <ul><li   >{{ message }}</li></ul>
                </span>
            {% endfor %}
        </div>
        <div class="mb-3">
            <label class="fw-semibold mb-1">Nouveau mot de passe</label>
            {{form_widget(form.password.first)}}
            <span class="form_errors">{{form_errors(form.password.first)}}</span>
            <span class="form_errors">{{form_errors(form.password)}}</span>
        </div>
        <div class="mb-3">
            <label class="fw-semibold mb-1">Confirmez le mot de passe</label>
            {{form_widget(form.password.second)}}
            <span class="form_errors">{{form_errors(form.password.second)}}</span>
        </div>
        <button type="submit" class="btn btn-success">Modifier le mot de passe</button>
        {{form_end(form)}}
    </form>
</div>
{% endblock %}