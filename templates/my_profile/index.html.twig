    <div class="card border-0 rounded-4 shadow-sm p-4 mb-4">
        <div class="d-flex justify-content-between align-items-start">
            <div class="d-flex align-items-center gap-4">
                <div class="position-relative">
                    <img src="" alt="Photo de profil" class="rounded-circle" style="width: 100px; height: 100px; object-fit: cover;">
                    <div class="position-absolute bottom-0 end-0 bg-success rounded-circle d-flex justify-content-center align-items-center" style="width: 30px; height: 30px;">
                        <i class="fa-solid fa-pen text-white" style="font-size: 12px;"></i>
                    </div>
                </div>
                <div>
                    <h2 class="fw-bold mb-0" style="color: #1a2e44;">Sophie Martin</h2>
