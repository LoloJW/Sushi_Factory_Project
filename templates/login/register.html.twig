{% extends "base/login.html.twig" %}
{% block main %}
<div class="d-flex justify-content-center align-items-start box_form mb-4">
    <div class="form_center shadow px-2">
        <div class="d-flex justify-content-start"><h2 class="fw-bold">Inscription</h2></div>
        <div class="middle_form">
            {{form_start(form,{'attr': {'novalidate': 'novalidate', 'class': 'w-100'}})}}
                <div class="d-flex flex-column div_input my-1 mt-2">
                    <label for="registration_form_lastName" class="mb-1">Nom</label>
                    {{form_widget(form.lastName)}}
                    <span class="form_errors">{{form_errors(form.lastName)}}</span>
                </div>
                <div class="d-flex flex-column div_input my-1 mt-2">
                    <label for="registration_form_firstName" class="mb-1">Prénom</label>
                    {{form_widget(form.firstName)}}
                    <span class="form_errors">{{form_errors(form.firstName)}}</span>
                </div>
                <div class="d-flex flex-column div_input my-1 mt-2">
                    <label for="registration_form_email" class="mb-1">Email</label>
                    {{form_widget(form.email)}}
                    <span class="form_errors">{{form_errors(form.email)}}</span>
                </div>
                <div class="d-flex flex-column div_input my-1 mt-2">
                    <label for="registration_form_password_first" class="mb-1">Mot de passe</label>
                    {{form_widget(form.password.first, {'attr': {'class': 'password_1'}})}}
                    <span class="form_errors">{{form_errors(form.password.first)}}</span>
                    <span class="form_errors">{{form_errors(form.password)}}</span>
                </div>
                <div class="d-flex flex-column div_input my-1 mt-2">
                    <label for="registration_form_password_second" class="mb-1">Confirmez le mot de pass</label>
                    {{form_widget(form.password.second, {'attr': {'class': 'password_2'}})}}
                </div>
                <div class="password_restriction_box mt-3 mb-2">
                    <p class="fw-bold">Le mot de passe doit contenir :</p>
                    <ul>
                        <li class="char_mdp">Au moins 12 caractères</li>
                        <li class="majuscule_mdp">Au moins une majuscule</li>
                        <li class="minuscule_mdp">Au moins une minuscule</li>
                        <li class="chiffre_mdp">Au moins un chiffre</li>
                        <li class="special_char_mdp">Au moins un caractère special</li>
                        <li class="match_mdp">Les mots de passe doivent correspondre</li>
                    </ul>
                </div>
                <div class="w-100"><button type="submit" class="btn btn-success text-white w-100 text-center align-content-center fw-bold enter-login mt-2 verification_event">S'inscrire</button></div>
            {{form_end(form)}}
        </div>
        <div>
            <hr class="my-3">
            <div class="">
                <span>Déjà inscript ?</span><a href="{{path('app_login')}}"> Veuillez vous connecter</a>
            </div>
        </div>
    </div>
</div>
{% endblock %}