{% extends "base/admin.html.twig" %}

{% block main %}
<div class="bg-light d-flex flex-column align-items-center justify-content-center">

<div class="card form_center shadow px-2 w-75 position-static m-5">
    <h2>Crée une salle</h2>
    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
    <div>
        <label for="{{ form.roomNumber.vars.id }}">Numéro de salle:</label>
        {{ form_widget(form.roomNumber) }}
        <span class="text-danger">{{ form_errors(form.roomNumber) }}</span>
    </div>
    <div>
        <label for="{{ form.capacity.vars.id }}">Capacité de salle:</label>
        {{ form_widget(form.capacity) }}
        <span class="text-danger">{{ form_errors(form.capacity) }}</span>
    </div>
    <div>
        <label for="{{ form.projector.vars.id }}">Projecteur dans la salle:</label>
        {{ form_widget(form.projector) }}
        <span class="text-danger">{{ form_errors(form.projector) }}</span>
    </div>
    <div class="">
        <label for="{{form.whiteboard.vars.id}}">Tableau dans la salle:</label>
         {{ form_widget(form.whiteboard) }}
         <span class="text-danger">{{ form_errors(form.whiteboard) }}</span>
    </div>
    <button type="submit" class="btn btn-success mt-3">Crée la salle</button>
    
    {{ form_end(form) }}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</div>
{% endblock %}