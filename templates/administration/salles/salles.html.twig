{% extends "base/admin.html.twig" %}

{% block main %}
<div class="bg-light">
    <div class="container-fluid px-4 py-4">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h1 class="fw-bold fs-4 mb-0">Gestion des Salles</h1>
                <p class="text-muted small mb-0">Vue d'ensemble et modifications</p>
            </div>
            <a href="{{path("app_new_salles")}}"class="btn btn-success text-white fw-semibold px-3 py-2">
                <i class="fa-solid fa-circle-plus me-1"></i> Ajouter
            </a>
        </div>
        {% for message in app.flashes('success') %}
            <span class="text-success fw-semibold">{{message}}</span>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <span class="text-danger fw-semibold">{{message}}</span>
        {% endfor %}

        <div>
            <table id="table-salles" class="table table-borderless Datatables_Css cell-border" style="cursor:default">
                <thead>
                    <tr>
                        <th class="text-center align-middle">Numéro de Salle</th>
                        <th class="text-center align-middle">Capacité</th>
                        <th class="text-center align-middle">Vidéo-Projecteur</th>
                        <th class="text-center align-middle">Tableau</th>
                        <th class="text-center align-middle">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for room in rooms %}
                    <tr class="fs-4 text-center align-middle">
                        <td class="text-center">{{ room.roomNumber }}</td>
                        <td class="text-center">{{ room.capacity }}</td>
                        <td>{{ room.projector ? 'Oui' : 'Non' }}</td>
                        <td>{{ room.whiteboard ? 'Oui' : 'Non' }}</td>
                        <td style="cursor:default" class="text-center">
                            <div class="my-1">
                                <a href="{{path("app_edit_salles",{"id":room.id})}}" class="admin_action text-center">
                                    <i class="fa-regular fa-pen-to-square text-secondary"></i>
                                </a>
                            </div>
                            <form class="my-1" action="{{path("app_delete_salles",{"id":room.id})}}" method="POST">
                                <input type="hidden" name="danger" value="{{csrf_token('_token'~room.id)}}">
                                <button type="submit" class="admin_action admin_delete_btn btn btn-link p-0">
                                    <i class="fa-regular fa-trash-can text-danger"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</div>
{% endblock %}