{% extends "base/admin.html.twig" %}

{% block main %}
<div class="container">
    <div class="container-fluid px-4 py-4">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="fw-bold fs-4 mb-0" style="color: #1a2e44;">Gestion des Salles</h1>
            <p class="text-muted small mb-0">Vue d'ensemble et modifications</p>
        </div>
        <button class="btn text-white fw-semibold px-3 py-2" style="background-color: #00897b; border-radius: 8px;">
            <i class="fa-solid fa-circle-plus me-1"></i> Ajouter
        </button>
    </div>

    <!-- Recherche -->
    <div class="mb-4">
        <div class="input-group" style="max-width: 350px;">
            <span class="input-group-text bg-white border-end-0" style="border-radius: 20px 0 0 20px; border-color: #dee2e6;">
                <i class="fa-solid fa-magnifying-glass text-muted"></i>
            </span>
            <input type="text" class="form-control border-start-0 ps-0" placeholder="Rechercher..." style="border-radius: 0 20px 20px 0; border-color: #dee2e6;">
        </div>
    </div>

    <!-- Tableau -->
    <table class="table table-borderless">
        <thead>
            <tr class="border-bottom">
                <th class="fw-bold text-dark pb-3" style="width: 30%;">Nom de la salle</th>
                <th class="fw-bold text-dark pb-3" style="width: 25%;">Capacité</th>
                <th class="fw-bold text-dark pb-3" style="width: 25%;">Étage</th>
                <th class="fw-bold text-dark pb-3 text-end" style="width: 20%;">Actions</th>
            </tr>
        </thead>
        <tbody>
            <tr class="border-bottom align-middle">
                <td class="fw-bold py-3">Salle 1</td>
                <td class="text-muted py-3">7 personnes</td>
                <td class="text-muted py-3">1</td>
                <td class="py-3 text-end">
                    <i class="fa-regular fa-pen-to-square me-2 text-secondary" style="cursor:pointer;"></i>
                    <i class="fa-regular fa-trash-can text-danger" style="cursor:pointer;"></i>
                </td>
            </tr>
            <tr class="border-bottom align-middle">
                <td class="fw-bold py-3">Salle 2</td>
                <td class="text-muted py-3">5 personnes</td>
                <td class="text-muted py-3">3</td>
                <td class="py-3 text-end">
                    <i class="fa-regular fa-pen-to-square me-2 text-secondary" style="cursor:pointer;"></i>
                    <i class="fa-regular fa-trash-can text-danger" style="cursor:pointer;"></i>
                </td>
            </tr>
            <tr class="border-bottom align-middle">
                <td class="fw-bold py-3">Salle 3</td>
                <td class="text-muted py-3">11 personnes</td>
                <td class="text-muted py-3">3</td>
                <td class="py-3 text-end">
                    <i class="fa-regular fa-pen-to-square me-2 text-secondary" style="cursor:pointer;"></i>
                    <i class="fa-regular fa-trash-can text-danger" style="cursor:pointer;"></i>
                </td>
            </tr>
            <tr class="border-bottom align-middle">
                <td class="fw-bold py-3">Salle 4</td>
                <td class="text-muted py-3">7 personnes</td>
                <td class="text-muted py-3">1</td>
                <td class="py-3 text-end">
                    <i class="fa-regular fa-pen-to-square me-2 text-secondary" style="cursor:pointer;"></i>
                    <i class="fa-regular fa-trash-can text-danger" style="cursor:pointer;"></i>
                </td>
            </tr>
            <tr class="border-bottom align-middle">
                <td class="fw-bold py-3">Salle 5</td>
                <td class="text-muted py-3">5 personnes</td>
                <td class="text-muted py-3">2</td>
                <td class="py-3 text-end">
                    <i class="fa-regular fa-pen-to-square me-2 text-secondary" style="cursor:pointer;"></i>
                    <i class="fa-regular fa-trash-can text-danger" style="cursor:pointer;"></i>
                </td>
            </tr>
        </tbody>
    </table>
</div>
{% endblock %}