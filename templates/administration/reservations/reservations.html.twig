{% extends "base/admin.html.twig" %}

{% block main %}
<div class="bg-light">
    <div class="container-fluid px-4 py-4">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h1 class="fw-bold fs-4 mb-0">Gestion des Réservations</h1>
                <p class="text-muted small mb-0">Vue d'ensemble et modifications</p>
            </div>
            <a href="{{path("app_new_salles")}}"class="btn btn-success text-white fw-semibold px-3 py-2">
                <i class="fa-solid fa-circle-plus me-1"></i> Ajouter
            </a>
        </div>
        {% for message in app.flashes('success') %}
            <span class="text-success fw-semibold">{{message}}</span>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <span class="text-success fw-semibold">{{message}}</span>
        {% endfor %}

        <div>
            <table id="table-reservations" class="table" style="cursor:default">
                <thead>
                    <tr>
                        <th>Créateur</th>
                        <th>Titre</th>
                        <th>Salles</th>
                        <th>Catégories</th>
                        <th>Création</th>
                        <th>Début</th>
                        <th>Fin</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for reservation in reservations %}
                    <tr class="align-middle" style="cursor:default">
                        <td style="cursor:default">    
                            {{reservation.user.lastName}} {{reservation.user.firstName}}
                        </td>
                        <td style="cursor:default">{{reservation.name}}</td>
                        <td style="cursor:default">{{reservation.room.roomNumber}}</td>
                        <td style="cursor:default" class="reserved-{{reservation.type.value}}">{{reservation.type.value}}</td>
                        <td>{{reservation.createdAt|date('d/m/Y à H:i')}}</td>
                        <td>{{reservation.timeStart|date('H:i')}}</td>
                        <td>{{reservation.timeEnd|date('H:i')}}</td>
                        <td style="cursor:default">{{reservation.reservedFor|date('d/m/Y')}}</td>
                        <td style="cursor:default" class="text-center">
                            <div class="my-1">
                                <a href="{{path("app_employes_edit", {"id":reservation.id})}}" class="text-center">
                                    <i class="fa-regular fa-pen-to-square text-secondary" style="font-size: 20px;"></i>
                                </a>
                            </div>
                            <form class="my-1" action="{{path("app_delete_reservations", {"id":reservation.id})}}" method="POST">
                                <input type="hidden" name="_token" value="{{csrf_token('reservation'~reservation.id)}}">
                                <button type="submit" class="admin_delete_btn btn btn-link p-0">
                                    <i class="fa-regular fa-trash-can text-danger" style="font-size: 20px;"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
        
    </div>
</div>
{% endblock %}