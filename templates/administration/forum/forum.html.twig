{% extends "base/admin.html.twig" %}

{% block main %}
<div class="container-fluid px-4 py-4">
    <h1 class="fw-bold fs-4 mb-4" style="color: #1a2e44;">Gestion du Forum</h1>

    <div class="row g-4">
        <div class="col-lg-4 col-md-6">
            <a href="{{ path('app_admin_forum_subject') }}">
                <div class="card border-0 rounded-4 shadow-sm p-3">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="rounded-3 p-2" style="background-color: #e8f0fe;">
                            <i class="fa-solid fa-globe fa-lg" style="color: #4361ee;"></i>
                        </div>
                        <span class="fw-bold fs-4">{{ publicSubjects | length }}</span>
                    </div>
                    <h5 class="fw-bold mb-1">Public</h5>
                    <p class="text-muted small mb-0">{{ publicSubjects | length }} sujets</p>
                </div>
            </a>
        </div>

        <div class="col-lg-4 col-md-6">
            <a href="{{ path('app_admin_forum_private') }}">
                <div class="card border-0 rounded-4 shadow-sm p-3">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="rounded-3 p-2" style="background-color: #fff3e0;">
                            <i class="fa-solid fa-lock fa-lg" style="color: #f77f00;"></i>
                        </div>
                        <span class="fw-bold fs-4">{{ privateSubjects | length }}</span>
                    </div>
                    <h5 class="fw-bold mb-1">Réunion</h5>
                    <p class="text-muted small mb-0">{{ privateSubjects | length }} sujets</p>
                </div>
            </a>
        </div>

        <div class="col-lg-4 col-md-6">
            <a href="{{ path('app_admin_forum_annonce') }}">
                <div class="card border-0 rounded-4 shadow-sm p-3">
                    <div class="d-flex justify-content-between align-items-start mb-4">
                        <div class="rounded-3 p-2" style="background-color: #f3e8ff;">
                            <i class="fa-solid fa-bullhorn fa-lg" style="color: #9b59b6;"></i>
                        </div>
                        <span class="fw-bold fs-4">{{ annonces | length }}</span>
                    </div>
                    <h5 class="fw-bold mb-1">Annonce</h5>
                    <p class="text-muted small mb-0">{{ annonces | length }} sujets</p>
                </div>
            </a>
        </div>
    </div>
</div>
{% endblock %}