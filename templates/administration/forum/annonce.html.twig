{% extends "base/admin.html.twig" %}

{% block main %}
<div class="bg-light">
    <div class="container-fluid px-4 py-4">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h1 class="fw-bold fs-4 mb-0">Gestion des Annonces</h1>
                <p class="text-muted small mb-0">Vue d'ensemble et modifications</p>
            </div>
            <a  href="{{path("app_admin_forum_new_annonce")}}"class="btn btn-success text-white fw-semibold px-3 py-2">
                <i class="fa-solid fa-circle-plus me-1"></i> Ajouter
            </a>
        </div>
        {% for message in app.flashes("success") %}
          <span class="text-success fw-semibold">{{message}}</span>  
        {% endfor %}
        {% for message in app.flashes("error") %}
          <span class="text-danger fw-semibold">{{message}}</span>  
        {% endfor %}
        <table id="table-annonces" class="table" style="cursor:default">
            <thead>
                <tr>
                    <th>Titre</th>
                    <th>Auteur</th>
                    <th>Créé le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for annonce in annonces %}
                    <tr>
                        <td>{{ annonce.title }}</td>
                        <td>{{ annonce.user.firstName }} {{ annonce.user.lastName }}</td>
                        <td>{{ annonce.createdAt|date('d/m/Y') }}</td>
                        <td style="cursor:default" class="text-center">
                            <div class="my-1">
                                <a href="{{path("app_admin_forum_annonce_edit",{"id":annonce.id})}}" class="admin_action text-center">
                                    <i class="fa-regular fa-pen-to-square text-secondary"></i>
                                </a>
                            </div>
                            <form class="my-1" action="{{path("app_admin_forum_annonce_delete",{"id":annonce.id})}}" method="POST">
                                <input type="hidden" name="_token" value="{{csrf_token('delete'~annonce.id)}}">
                                <button type="submit" class="admin_action admin_delete_btn btn btn-link p-0">
                                    <i class="fa-regular fa-trash-can text-danger"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}