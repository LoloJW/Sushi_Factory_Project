{% extends "base/admin.html.twig" %}

{% block main %}
<div class="bg-light">
    <div class="container-fluid px-4 py-4">
        <div class="d-flex justify-content-between align-items-start mb-4">
            <div>
                <h1 class="fw-bold fs-4 mb-0">Gestion des Sujets</h1>
                <p class="text-muted small mb-0">Vue d'ensemble et modifications</p>
            </div>
        </div>
        <table id="table-subjects" class="table" style="cursor:default">
            <thead>
                <tr>
                    <th>Titre</th>
                    <th>Auteur</th>
                    <th>Créé le</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for subject in publicSubjects %}
                    <tr>
                        <td>{{ subject.title }}</td>
                        <td>{{ subject.user.firstName }} {{ subject.user.lastName }}</td>
                        <td>{{ subject.createdAt|date('d/m/Y') }}</td>
                        <td></td>
                            
                    </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}