{% extends "base/admin.html.twig" %}

{% block main %}
<body class="bg-light">

<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h1 class="fw-bold fs-4 mb-0">Gestion des Employés</h1>
            <p class="text-muted small mb-0">Vue d'ensemble et modifications</p>
        </div>
        <button class="btn btn-success text-white fw-semibold px-3 py-2">
            <i class="fa-solid fa-circle-plus me-1"></i> Ajouter
        </button>
    </div>

    <div>
        <table id="table-employes" class="table table-borderless Datatables_Css">
            <thead>
                <tr>
                    <th>Avatar</th>
                    <th>Nom</th>
                    <th>Prénom</th>
                    <th>Email</th>
                    <th>Rôle</th>
                    <th>Inscrit Depuis</th>
                    <th>Statut</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
        
                <tr>
            
                
                    <td>    {% if user.imgProfile %}
                    asEZFZEFZEFZER
                    {% else %}
                        iiiiiiiiiiiiii
                {% endif %}</td>
                    <td>{{user.lastName}}</td>
                    <td>{{user.firstName}}</td>
                    <td>{{user.email}}</td>
                    <td>{{user.roles[0]}}</td>
                    <td>{{user.joinedAt|date('d/m/Y')}}</td>
                    <td>
                    {% if user.isVerified == true %}
                        Vérifié
                    {% else %}
                        Non Vérifié
                    {% endif %}
                    </td>
                    <td>
                        <i class="fa-regular fa-pen-to-square me-2 text-secondary" style="cursor:pointer;"></i>
                        <i class="fa-regular fa-trash-can text-danger" style="cursor:pointer;"></i>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
{% endblock %}