{% extends "base/admin.html.twig" %}

{% block main %}
<div class="bg-light d-flex flex-column align-items-center justify-content-center">

<div class="card form_center shadow px-2 w-75 position-static m-5">
    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}
    
    <div>
        <label for="{{ form.lastName.vars.id }}">Nom:</label>
        {{ form_widget(form.lastName) }}
    </div>
    <div>
        <label for="{{ form.firstName.vars.id }}">Prénom:</label>
        {{ form_widget(form.firstName) }}
    </div>
    <div>
        <label for="{{ form.email.vars.id }}">Email:</label>
        {{ form_widget(form.email) }}
    </div>
    <div class="d-flex justify-content-start align-items-center">
        <div class=" d-flex justify-content-between align-items-center w-100">
            <div><label for="{{ form.roles.vars.id }}">Roles:</label></div>
            <div class="d-flex justify-content-between">
                {% for choice in form.roles %}
                <div class="mx-2">
                    {{ form_widget(choice) }}
                    {{ form_label(choice) }}
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
    <div>
        <label for="{{ form.isVerified.vars.id }}" class="me-2">Compte vérifié:</label>
        {{ form_widget(form.isVerified) }}
    </div>
    <div>
        <label class="me-2">Avatar:</label>
        {{ form_widget(form.imgFile, {'label_attr':{'class':'me-2'}}) }}
        {% if form.vars.data.ImgProfile %}
            <div class="avatar_box"><img src="{{asset("images/avatars/"~form.vars.data.imgProfile) }}" alt="" class="avatar"></div>
        {% else %}
            <div class="avatar_box"><img src="{{asset("images/avatar.png") }}" alt="" class="avatar"></div>
        {% endif %}
        
    </div>
    
    <button type="submit" class="btn btn-success mt-3">Valider les modification</button>
    
    {{ form_end(form) }}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</div>
{% endblock %}